{
  "_comment": "活跃 .vmt 材质 — 当前生效的 Valve Material Type 文件。用 like + ends_with 快速定位材质资源。",
  "_usage": "store.execute(json.load(open('queries/active_vmt_files.json')))",
  "_note": "v2 引擎新增 ends_with/contains/starts_with 字符串谓词，可直接过滤扩展名和路径模式。",
  "select": ["virtual_path", "source_name", "priority"],
  "from": "files",
  "where": {
    "and": [
      {"eq": ["is_active", true]},
      {"like": ["virtual_path", "materials/*.vmt"]}
    ]
  },
  "order_by": {"by": "source_name", "dir": "asc"},
  "limit": 500
}
