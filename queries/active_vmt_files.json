{
  "_comment": "活跃文件按扩展名统计 — 当前生效的文件中，各扩展名的数量分布。快速了解资源构成。",
  "_usage": "store.execute(json.load(open('queries/active_by_extension.json')))",
  "_note": "此查询无法用 JSON DSL 精确完成（需要 Python lambda 提取扩展名）。替代方案：用 like 过滤常见类型。以下示例列出 .vmt 材质文件。",
  "select": ["virtual_path", "source_name", "priority"],
  "from": "files",
  "where": {
    "and": [
      {"eq": ["is_active", true]},
      {"like": ["virtual_path", "materials/%.vmt"]}
    ]
  },
  "order_by": {"by": "source_name", "dir": "asc"},
  "limit": 100
}
